// This is the initial Prisma schema file for the MedQs medical education platform.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(255)
  password      String   @db.VarChar(255)
  universities   University[]
  forums        Forum[]
  notifications Notifications[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model University {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  users     User[]
  content   Content[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model AcademicStructure {
  id               Int       @id @default(autoincrement())
  universityId     Int
  type             String     // e.g., "Undergraduate", "Postgraduate"
  structureDetails String     // e.g., details about the structure
  university University @relation(fields: [universityId], references: [id])
}

model Content {
  id          Int       @id @default(autoincrement())
  title       String     @db.VarChar(255)
  description String?
  universityId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  university University @relation(fields: [universityId], references: [id])
}

model Forum {
  id        Int        @id @default(autoincrement())
  userId    Int
  title     String     @db.VarChar(255)
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user     User @relation(fields: [userId], references: [id])
}

model Notifications {
  id          Int       @id @default(autoincrement())
  userId      Int
  message      String   @db.VarChar(255)
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user     User @relation(fields: [userId], references: [id])
}

model Gamification {
  id          Int      @id @default(autoincrement())
  userId      Int
  points      Int      @default(0)
  badges      String[] // list of badges earned
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user     User @relation(fields: [userId], references: [id])
}

model Admin {
  id          Int      @id @default(autoincrement())
  userId      Int
  permissions String[]    // e.g., "manageUsers", "viewReports"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user     User @relation(fields: [userId], references: [id])
}